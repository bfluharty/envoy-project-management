# Application runtime
NODE_ENV=development
APP_ENV=dev
HOST=localhost
PORT=8080
LOG_LEVEL=debug

# Application security
# Generate a secure key: node ace generate:key (writes here but does not display it)
# To display the key after generating: grep '^APP_KEY=' .env
# To display without writing: node ace generate:key --show
APP_KEY=

# Public application URL
# Used in reset-password links, OAuth callbacks, and other absolute URLs.
APP_URL=http://localhost:8080

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_DATABASE=envoy_db_dev

# Session and authentication
SESSION_DRIVER=cookie
PASSWORD_AUTH_ENABLED=false

# Reasoning engine
REASONING_ENGINE_URL=http://localhost:8081

# Email service
# Envoy project-management calls envoy-email-service for sending, inbox reads, watches, and provider sync.
# Base URL, no trailing slash. Required for inbox reply.
# App on host: http://127.0.0.1:8083
# App in Docker: use http://host.docker.internal:8083 so the container can reach SAM local on the host
# Endpoints: /send-on-behalf, /inbox/list, /inbox/message, /watches/*.
EMAIL_SERVICE_URL=http://127.0.0.1:8083
EMAIL_SERVICE_API_KEY=
EMAIL_TERMS_VERSION=2026-06-26-email-access-v1

# Email sync queue
# Required for provider push webhook processing and background sync workers.
EMAIL_SYNC_QUEUE_URL=
EMAIL_SYNC_DLQ_URL=

# Email provider push configuration
# Required for live Gmail Pub/Sub and Microsoft Graph webhooks.
GMAIL_PUBSUB_TOPIC=
MICROSOFT_GRAPH_NOTIFICATION_URL=
MICROSOFT_GRAPH_LIFECYCLE_URL=
MICROSOFT_GRAPH_CLIENT_STATE_SECRET=

# OAuth clients
# Social login callback URLs:
# - APP_URL/auth/google/callback
# - APP_URL/auth/microsoft/callback
# Inbox connection callback URL:
# - APP_URL/inbox/callback
# Google: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Microsoft: https://portal.azure.com - App registration
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# Transactional email
# Optional: only if config/mail Resend mailer is used elsewhere.
MAIL_FROM_ADDRESS=onboarding@resend.dev
MAIL_FROM_NAME=Envoy
RESEND_API_KEY=

# Vendor discovery
FOURSQUARE_PLACES_API_KEY=
