# Application Configuration
NODE_ENV=development
PORT=8080
# Generate a secure key using: node ace generate:key
APP_KEY=
HOST=localhost
LOG_LEVEL=debug

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_DATABASE=envoy_db_dev

# Session Configuration
SESSION_DRIVER=cookie

# Reasoning Engine URLs
REASONING_ENGINE_URL_DEV=http://localhost:8081/reasoning/chat
REASONING_ENGINE_URL_PROD=

# Mail (transactional via Resend — https://resend.com; get API key and optionally verify your domain)
APP_URL=http://localhost:8080
MAIL_FROM_ADDRESS=onboarding@resend.dev
MAIL_FROM_NAME=Envoy
RESEND_API_KEY=