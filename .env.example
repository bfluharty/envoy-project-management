# Instructions: Copy this file to .env and reach out to an admin to fill in any missing values.
# Never commit your .env file to source control.

# App
NODE_ENV=development            # Informs how AdonisJS builds the application [development, production, test]
APP_ENV=local                   # Traditional environment value that is used for dictating app behavior [local, dev, prod, test] 
HOST=localhost                  
PORT=8080                       
APP_URL=http://$HOST:$PORT      # Supports middleware/callbacks
LOG_LEVEL=debug                 # Controls the verbosity of logs [silent, fatal, error, warn, info, debug, trace]
SESSION_DRIVER=cookie           # Used for session management [cookie, memory]
APP_KEY=                        # Generate with: `node ace generate:key` and paste here

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_DATABASE=envoy_db_dev

# Internal services
REASONING_ENGINE_URL=http://localhost:8081
REASONING_ENGINE_API_KEY=
EMAIL_SERVICE_URL=http://localhost:8083
EMAIL_SERVICE_API_KEY=

# External services
FOURSQUARE_PLACES_API_KEY=

# Third party auth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# Email sync - disabled by default in local development. Enable to test background sync workers and provider push webhooks.
EMAIL_SYNC_WORKER_ENABLED=false
EMAIL_SYNC_WORKER_INTERVAL_SECONDS=60
EMAIL_SYNC_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/362850210751/envoy-email-sync-events-dev
EMAIL_SYNC_DLQ_URL=https://sqs.us-east-1.amazonaws.com/362850210751/envoy-email-sync-events-dev-dlq

#Feature flags
PASSWORD_AUTH_ENABLED=false     # Used previously to support traditional username/password registration.
