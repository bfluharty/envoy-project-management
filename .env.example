# Application Configuration
NODE_ENV=development
APP_ENV=dev
PORT=8080
# Generate a secure key: node ace generate:key (writes here but does not display it)
# To display the key after generating: grep '^APP_KEY=' .env
# To display without writing: node ace generate:key --show
APP_KEY=
HOST=localhost
LOG_LEVEL=debug

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_DATABASE=envoy_db_dev

# Session Configuration
SESSION_DRIVER=cookie

# Reasoning Engine URLs
REASONING_ENGINE_URL=http://localhost:8081/reasoning/chat

# App URL (used in reset-password links, etc.)
APP_URL=http://localhost:8080

# Email + inbox: envoy-email-service only. Inbox replies are sent only via this service (no direct Gmail/Microsoft).
# Base URL, no trailing slash. Required for inbox reply.
# App on host: http://127.0.0.1:3000
# App in Docker: use http://host.docker.internal:3000 so the container can reach SAM local on the host
# Endpoints: /send-on-behalf, /inbox/list, /inbox/message. See docs/EMAIL-SERVICE-FLOW.md.
EMAIL_SERVICE_URL=http://127.0.0.1:3000
EMAIL_SERVICE_API_KEY=

# Optional: only if config/mail Resend mailer is used elsewhere (transactional email uses EMAIL_SERVICE_URL)
MAIL_FROM_ADDRESS=onboarding@resend.dev
MAIL_FROM_NAME=Envoy
RESEND_API_KEY=

# Inbox OAuth (customer connects Gmail/Outlook; we listen and reply on their behalf)
# Google: https://console.cloud.google.com/apis/credentials — OAuth 2.0 Client, redirect URI: APP_URL/inbox/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Microsoft: https://portal.azure.com — App registration, redirect URI: APP_URL/inbox/callback, API permissions: Mail.Read Mail.Send User.Read offline_access
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=