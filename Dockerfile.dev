FROM node:22-alpine

WORKDIR /app

COPY docker-entrypoint.dev.sh /usr/local/bin/docker-entrypoint.dev.sh
# Ensure the script is executable and convert any CRLF -> LF to avoid shebang issues on Linux
RUN chmod +x /usr/local/bin/docker-entrypoint.dev.sh && \
	sed -i 's/\r$//' /usr/local/bin/docker-entrypoint.dev.sh

EXPOSE 8080

ENTRYPOINT ["/usr/local/bin/docker-entrypoint.dev.sh"]
CMD ["npm", "run", "dev"]
